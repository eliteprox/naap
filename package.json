    "standard-as-callback": "2.1.0",
    "vitest": "4.1.10"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.2"
  },
  "devDependencies": {
    "@nx/js": "^22.7.6",
    "@nx/node": "^22.7.6",
    "@nx/react": "^22.7.6",
    "@nx/vite": "^22.7.6",
    "@nx/web": "^22.7.6",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "^0.5.23",
    "@types/node": "^20.19.43",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "nx": "^22.6.5",
    "postcss": "^8.5.16",
    "prettier": "~3.9.5",
    "puppeteer": "^24.43.1",
    "tailwindcss": "^3.4.15",
    "tslib": "^2.3.0",
    "tsx": "^4.23.0",
    "typescript": "~5.9.3",
    "vite": "8.1.4"
  },
  "overrides": {
    "axios": "^1.15.0",
    "esbuild": "0.28.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "minimatch": "10.2.5",
    "eslint-plugin-import": {
      "minimatch": "10.2.5"
    },
    "eslint-plugin-jsx-a11y": {
      "minimatch": "10.2.5"
    },
    "eslint-plugin-react": {
      "minimatch": "10.2.5"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "10.2.5"
    }
  },
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/workflows/*",
    "services/*",
    "services/workflows/*",
    "plugins/*/frontend",
