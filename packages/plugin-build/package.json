{
  "name": "@naap/plugin-build",
  "version": "0.1.0",
  "description": "Shared build configuration for NAAP plugins",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.js"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.15",
    "vite": "8.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "naap",
    "plugin",
    "build",
    "vite",
    "umd"
  ],
  "author": "NAAP Team",
  "license": "MIT"
}
